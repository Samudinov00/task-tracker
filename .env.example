# ══════════════════════════════════════════════════════════════════════════════
# .env.example — шаблон переменных окружения
# Скопируйте в .env и заполните значения:
#   cp .env.example .env
# НИКОГДА не коммитьте .env в репозиторий!
# ══════════════════════════════════════════════════════════════════════════════

# ── Django ────────────────────────────────────────────────────────────────────
# Генерация: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-replace-me-with-a-strong-random-key

# False в продакшене — обязательно!
DEBUG=False

# Ваш домен и IP сервера через запятую (без пробелов)
ALLOWED_HOSTS=example.com,www.example.com,your-server-ip

# Если True — использует SQLite вместо PostgreSQL (только для локальной разработки)
USE_SQLITE=False

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_NAME=tasktracker
DB_USER=tasktracker_user
DB_PASSWORD=strong-random-password-here
# В Docker Compose имя сервиса = хост; для локальной разработки — localhost
DB_HOST=db
DB_PORT=5432

# ── Gunicorn ──────────────────────────────────────────────────────────────────
# Рекомендуемое число workers: (2 * CPU_ядра) + 1
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=60
GUNICORN_KEEPALIVE=5
GUNICORN_LOG_LEVEL=info

# ── Docker ────────────────────────────────────────────────────────────────────
# Имя образа для docker-compose (задаётся при деплое из CI/CD или вручную)
# Пример: ghcr.io/your-github-username/task-tracker:latest
DOCKER_IMAGE=task-tracker:latest
